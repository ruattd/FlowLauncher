<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:FlowLauncher.Controls">

    <Design.PreviewWith>
        <c:FlowClickable/>
    </Design.PreviewWith>

    <Style Selector=":is(c|FlowClickable)">
        <!-- Set Defaults -->
        <Style Selector="^:pointerover, ^:focus">
            <Setter Property="PriorityBackgroundOpacity" Value=".3"/>
        </Style>
        <Style Selector="^:pressing, ^:checked">
            <Setter Property="PriorityBackgroundOpacity" Value="1"/>
        </Style>
        <Setter Property="Template">
            <ControlTemplate>
                <Border CornerRadius="{TemplateBinding CornerRadius}" ClipToBounds="True"
                        Margin="{TemplateBinding Margin}">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" Opacity="{TemplateBinding BackgroundOpacity}">
                            <Border.Transitions><Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:.1"/>
                            </Transitions></Border.Transitions>
                        </Border>
                        <Decorator Padding="{TemplateBinding Padding}">
                            <TemplatedControl DataContext="{TemplateBinding}" Template="{TemplateBinding ContentTemplate}"/>
                        </Decorator>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
        <Setter Property="Background" Value="{DynamicResource FlowAccent}"/>
        <Setter Property="BackgroundOpacity" Value="0"/>
    </Style>

</Styles>
